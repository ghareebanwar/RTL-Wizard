{
  "manifest_version": 3,
  "name": "RTL Wizard",
  "version": "3.0.0",
  "description": "RTL/LTR text direction toggle for Arabic, Hebrew, Syriac, and 200+ RTL languages with smart auto-detection.",
  "author": "Ghareeb Aleleiwi",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "contextMenus", "scripting", "activeTab"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "homepage_url": "https://github.com/ghareebanwar/RTL_Wizard"
}